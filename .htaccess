RewriteEngine On

# Remove www and always redirect to HTTPS
RewriteCond %{HTTP_HOST} ^www\.art-ratio\.com$ [NC]
RewriteRule ^ https://art-ratio.com%{REQUEST_URI} [L,R=301]

# Force HTTPS for the bare domain
RewriteCond %{HTTP_HOST} ^art-ratio\.com$ [NC]
RewriteCond %{HTTPS} off

# Catch-all HTTPS redirect (covers any other host variations)
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve clean URLs for the built static assets and pages.
# Prefer Arino template assets when present (for /about.html, /contact.html, ...),
# then fall back to built app assets.
RewriteCond %{DOCUMENT_ROOT}/Arino\ -\ Template/assets/$1 -f
RewriteRule ^assets/(.*)$ Arino\ -\ Template/assets/$1 [L,NC]
RewriteRule ^assets/(.*)$ dist/assets/$1 [L,NC]
RewriteRule ^js/(gtm-init|embed-vimeo-controls|video-thumb-inline|hero-vimeo-loop)\.js$ Arino\ -\ Template/assets/js/$1.js [L,NC]
RewriteRule ^js/(.*)$ dist/js/$1 [L,NC]
RewriteRule ^css/(.*)$ dist/css/$1 [L,NC]
RewriteRule ^profile(?:/index\.html)?/?$ dist/profile/index.html [L,NC]

# Serve favicon and related PWA assets from the built folder
RewriteRule ^favicon\.ico$ dist/favicon.ico [L,NC]
RewriteRule ^favicon_io/(.*)$ dist/favicon_io/$1 [L,NC]
RewriteRule ^site\.webmanifest$ dist/favicon_io/site.webmanifest [L,NC]

<IfModule mod_headers.c>
  # Internal/back-office routes
  SetEnvIf Request_URI "^/(dashboard|home|login|customer|technician|projects|projects-reports|projects-expenses|users|notifications|site-analytics|contact-inquiries|feedback-submissions|dashboard-local)(?:\\.html)?/?$" ar_private_page=1
  SetEnvIf Request_URI "^/(?:feedback(?:\\.html)?|en/feedback|آراء-العملاء|ar/آراء-العملاء)/?$" ar_feedback_page=1
  SetEnvIf Request_URI "^/(?:team-details-[a-z-]+(?:\\.html)?|en/team-details-[a-z-]+|(?:ar/)?[^/]*تفاصيل-الفريق)/?$" ar_team_details_page=1
  SetEnvIf Request_URI "^/(?:portfolio-details-[A-Za-z0-9-]+(?:\\.html)?|en/portfolio-details-[A-Za-z0-9-]+|(?:ar/)?(?:مشروع-صالة-كبار-الشخصيات-في-المطار|مشروع-بطولة-الجولف|مشروع-سعودي-دنت|ساندوتش-تيكا-من-الطازج|برج-ترامب-جدة|ريل-لأم-الزلف|الفيلم-النهائي-للستي-ووك-٢٠٢٤|ايفنت-هوبلو|ريل-لميت-ذا-فيش|معرض-الكتاب))/?$" ar_portfolio_details_page=1
  SetEnvIf Request_URI "^/(?:(?:blog|en/blog)/(?:event-coverage/professional-event-coverage-guide|filmmaking-techniques/cinematic-lighting-basics|product-photography/professional-product-photography-ecommerce|video-production/how-to-choose-professional-video-production-company)|(?:ar/)?(?:كشكولنا|المدونة)/(?:تغطية-الفعاليات/دليل-تغطية-الفعاليات-الاحترافية|تقنيات-صناعة-الافلام/اساسيات-الاضاءة-السينمائية|تصوير-المنتجات/دليل-تصوير-المنتجات-الاحترافي-للمتاجر-الالكترونية|انتاج-الفيديو/كيف-تختار-شركة-انتاج-فيديو-احترافية))/?$" ar_blog_articles_page=1
  SetEnvIf Request_URI "^/(?:portfolio[2-6](?:\\.html)?|en/portfolio[2-6]|portfolio[2-6]-details-video-[1-7](?:\\.html)?|en/portfolio[2-6]-details-video-[1-7]|(?:ar/)?(?:أعمالنا-[2-6]|ريل-إعلاني-لعبدالصمد-القرشي|ريل-للكوتش-البيتي-الفيصل|نهائي-دوري-أبطال-آسيا-للنخبة|توبا-ذا-ون|ايفنت-معوض|ريل-اليوم-الوطني|موفي-بوكس-الطازج|ريل-رنة-خلخال|اوفردوز-ايس-كريم|سفاري-اكستريم|تغطية-محلات-في-السيتي-ووك|فيديو-مجوهرات|فول-جرين-فارمز|صنع-في-باكستان|افتتاح-فرع-روومرز|تغطية-كشك-في-ويشن|كيكو-ميلانو|العروض-الجوالة-سيتي-ووك|قرية-التأسيس-عرعر|معرض-الكتاب-2|مقابلات-مختارة|في-60|مجوهرات|مجوهرات-2|اوفردوز-عام|قيمرية|ريل-للطريقة-المعينة|عدنان-خان-مجھ-سے-دور|كيكة-كوز|هنجرستيشن|ايوا|بوكس-الباربكيو-زد|اعلان-قهوة|تجمع-نادي-فيراري-السعودي|اعلان-ازار))/?$" ar_portfolio_legacy_cluster_page=1

  # Raw implementation paths should never be indexable
  SetEnvIf Request_URI "^/(?:src|public)/.*\\.html$" ar_private_page=1
  SetEnvIf Request_URI "^/dist/(?:src/pages/.*|(?!public-localized/).*\\.html)$" ar_private_page=1

  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_private_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_feedback_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_team_details_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_portfolio_details_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_blog_articles_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_portfolio_legacy_cluster_page
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=ar_excluded_header_page
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "^(equipment-requests-portal|shop-cart|shop-checkout|shop-wishlist|shop-order-recived)\.html$">
    Header always set X-Robots-Tag "noindex, follow, noarchive"
  </FilesMatch>
</IfModule>

# Reinforce excluded-cluster X-Robots-Tag delivery using rewrite env flags.
# This keeps the existing containment logic intact while avoiding gaps where
# SetEnvIf-based header matching does not surface on the final response.
RewriteRule ^(?:feedback(?:\.html)?|en/feedback|آراء-العملاء|ar/آراء-العملاء)/?$ - [E=ar_excluded_header_page:1,NC]
RewriteRule ^(?:team-details-[a-z-]+(?:\.html)?|en/team-details-[a-z-]+|(?:ar/)?[^/]*تفاصيل-الفريق)/?$ - [E=ar_excluded_header_page:1,NC]
RewriteRule ^(?:portfolio-details-[A-Za-z0-9-]+(?:\.html)?|en/portfolio-details-[A-Za-z0-9-]+|(?:ar/)?(?:مشروع-صالة-كبار-الشخصيات-في-المطار|مشروع-بطولة-الجولف|مشروع-سعودي-دنت|ساندوتش-تيكا-من-الطازج|برج-ترامب-جدة|ريل-لأم-الزلف|الفيلم-النهائي-للستي-ووك-٢٠٢٤|ايفنت-هوبلو|ريل-لميت-ذا-فيش|معرض-الكتاب))/?$ - [E=ar_excluded_header_page:1,NC]
RewriteRule ^(?:(?:blog|en/blog)/(?:event-coverage/professional-event-coverage-guide|filmmaking-techniques/cinematic-lighting-basics|product-photography/professional-product-photography-ecommerce|video-production/how-to-choose-professional-video-production-company)|(?:ar/)?(?:كشكولنا|المدونة)/(?:تغطية-الفعاليات/دليل-تغطية-الفعاليات-الاحترافية|تقنيات-صناعة-الافلام/اساسيات-الاضاءة-السينمائية|تصوير-المنتجات/دليل-تصوير-المنتجات-الاحترافي-للمتاجر-الالكترونية|انتاج-الفيديو/كيف-تختار-شركة-انتاج-فيديو-احترافية))/?$ - [E=ar_excluded_header_page:1,NC]
RewriteRule ^(?:portfolio[2-6](?:\.html)?|en/portfolio[2-6]|portfolio[2-6]-details-video-[1-7](?:\.html)?|en/portfolio[2-6]-details-video-[1-7]|(?:ar/)?(?:أعمالنا-[2-6]|ريل-إعلاني-لعبدالصمد-القرشي|ريل-للكوتش-البيتي-الفيصل|نهائي-دوري-أبطال-آسيا-للنخبة|توبا-ذا-ون|ايفنت-معوض|ريل-اليوم-الوطني|موفي-بوكس-الطازج|ريل-رنة-خلخال|اوفردوز-ايس-كريم|سفاري-اكستريم|تغطية-محلات-في-السيتي-ووك|فيديو-مجوهرات|فول-جرين-فارمز|صنع-في-باكستان|افتتاح-فرع-روومرز|تغطية-كشك-في-ويشن|كيكو-ميلانو|العروض-الجوالة-سيتي-ووك|قرية-التأسيس-عرعر|معرض-الكتاب-2|مقابلات-مختارة|في-60|مجوهرات|مجوهرات-2|اوفردوز-عام|قيمرية|ريل-للطريقة-المعينة|عدنان-خان-مجھ-سے-دور|كيكة-كوز|هنجرستيشن|ايوا|بوكس-الباربكيو-زد|اعلان-قهوة|تجمع-نادي-فيراري-السعودي|اعلان-ازار))/?$ - [E=ar_excluded_header_page:1,NC]

RewriteRule ^(dashboard|home|login|customer|technician|projects|projects-reports|projects-expenses|users|notifications)(?:\.html)?/?$ dist/src/pages/$1.html [L,NC]
RewriteRule ^equipment-requests-portal(?:\.html)?/?$ Arino\ -\ Template/equipment-requests-portal.html [L,NC]
# Redirect any legacy /src/pages/* paths to the built pages
RewriteRule ^src/pages/(.*)$ dist/src/pages/$1 [L,NC]

# Temporarily remove shop-product-details from public exposure while preserving the source.
RewriteRule ^en/shop-product-details/?$ /en/shop/ [R=302,L,NC]
RewriteRule ^تفاصيل-معدة/?$ /معداتنا/ [R=302,L,NC]
RewriteRule ^ar/تفاصيل-معدة/?$ /معداتنا/ [R=302,L,NC]
RewriteRule ^shop-product-details(?:\.html)?/?$ /en/shop/ [R=302,L,NC]

# Contain duplicate executable routes for the approved localized/public pages only.
# Do not broaden this to legacy detail pages, parked pages, or utility pages.
RewriteRule ^index\.html$ / [R=301,L,NC]
RewriteRule ^about\.html$ /en/about/ [R=301,L,NC]
RewriteRule ^contact\.html$ /en/contact/ [R=301,L,NC]
RewriteRule ^service\.html$ /en/service/ [R=301,L,NC]
