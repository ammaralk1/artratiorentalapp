# ASCII slug fallback routes (for direct file-name style URLs).
# Example: /about/ -> Arino - Template/about.html
RewriteCond %{REQUEST_URI} !^/(?:en|ar)(?:/|$) [NC]
RewriteCond %{DOCUMENT_ROOT}/Arino\ -\ Template/$1.html -f
RewriteRule ^([A-Za-z0-9-]+)/?$ Arino\ -\ Template/$1.html [L,NC]
# END I18N ROUTES

# Serve Arino template HTML pages at root without URL redirect:
# /about.html -> /Arino - Template/about.html (internal rewrite only)
RewriteCond %{REQUEST_URI} \.html$ [NC]
RewriteCond %{DOCUMENT_ROOT}/Arino\ -\ Template%{REQUEST_URI} -f
RewriteRule ^(.+\.html)$ Arino\ -\ Template/$1 [L,NC]

RewriteRule ^$ Arino\ -\ Template/index.html [L,NC]

Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 4 hours"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
  # Serve HTML with no-cache so clients always fetch the latest page (and thus latest hashed assets)
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|json|xml|svg|png|jpe?g|webp|woff2?)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
  # Video delivery tuning for faster mobile start:
  # - no-transform discourages CDN/proxy re-encoding/compression
  # - explicit ranges helps streaming/seeking behavior
  <FilesMatch "\.(mp4|webm|mov)$">
    Header set Cache-Control "public, max-age=604800, immutable, no-transform"
    Header set Accept-Ranges "bytes"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/css application/javascript text/javascript application/json application/xml image/svg+xml
  # Never gzip already-compressed video containers.
  SetEnvIfNoCase Request_URI "\.(mp4|webm|mov)$" no-gzip=1
  <IfModule mod_setenvif.c>
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  </IfModule>
  <IfModule mod_headers.c>
    Header append Vary Accept-Encoding
  </IfModule>
</IfModule>

# Serve the canonical CSP from the web server so that frame-ancestors is enforced.
# Keep any fallback <meta http-equiv="Content-Security-Policy"> definitions aligned,
# but omit frame-ancestors there to avoid browser warnings.
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self' blob:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://img1.wsimg.com https://uicdn.toast.com https://static.cloudflareinsights.com https://player.vimeo.com https://www.googletagmanager.com; connect-src 'self' https://art-ratio.com https://*.art-ratio.com https://cdn.jsdelivr.net https://img1.wsimg.com https://csp.secureserver.net https://uicdn.toast.com https://cloudflareinsights.com https://www.google-analytics.com https://region1.google-analytics.com https://stats.g.doubleclick.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://uicdn.toast.com; img-src 'self' data: blob: https://art-ratio.com https://*.art-ratio.com https://cdn.jsdelivr.net https://img1.wsimg.com https://assets.art-ratio.com https://*.vimeocdn.com https://www.googletagmanager.com; font-src 'self' https://fonts.gstatic.com data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; frame-src 'self' https://assets.art-ratio.com https://player.vimeo.com https://www.googletagmanager.com; worker-src 'self' blob:; upgrade-insecure-requests;"
</IfModule>
