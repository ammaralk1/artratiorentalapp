RewriteRule ^en/([A-Za-z0-9-]+)/?$ Arino\ -\ Template/$1.html [L,NC]

# Canonicalize legacy /ar URLs to the default-language clean routes.
RewriteRule ^ar/?$ / [R=301,L,NC]
